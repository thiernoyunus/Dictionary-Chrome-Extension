{
  "manifest_version": 3,
  "name": "Arabic Dictionary",
  "version": "1.3",
  "description": "Look Up Arabic Words on the Fly!",
  "permissions": ["storage"],
  "action": {
    "default_title": "Arabic Dictionary",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data/tableab",
        "data/tableac",
        "data/tablebc",
        "data/dictprefixes",
        "data/dictstems",
        "data/dictsuffixes"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["main.js", "libs/opentip-native.min.js"],
      "css": ["libs/opentip.css", "main.css"]
    }
  ]
}
